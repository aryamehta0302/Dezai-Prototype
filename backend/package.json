    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jose": "^6.2.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.5.0",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.0",

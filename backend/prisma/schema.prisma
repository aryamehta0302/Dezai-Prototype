// Dezai — Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  passwordHash String?
  role         UserRole  @default(STUDENT)
  onboarded    Boolean   @default(false)
  xp           Int       @default(0)
  streakCount  Int       @default(0)
  lastActiveAt DateTime? @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollments    Enrollment[]
  attempts       AssessmentAttempt[]
  notes          Note[]
  bookmarks      Bookmark[]
  progresses     Progress[]
  credentials    Credential[]        @relation("EarnedCredentials")
  issuedCerts    Credential[]        @relation("IssuedCredentials")
  violations     ViolationLog[]
  xpTransactions XpTransaction[]
  chatSessions   ChatSession[]
  notifications  Notification[]
  uploads        Upload[]
  auditLogs      AuditLog[]
  examSessions   ExamSession[]
  userAchievements UserAchievement[]

  facultyInfo   FacultyMember?
  instAdminInfo InstitutionAdmin?
  employeeInfo   Employee?
  orgAdminInfo   OrganizationAdmin?
  complianceAttempts ComplianceAssessmentAttempt[]

  @@map("users")
}

enum UserRole {
  STUDENT
  FACULTY
  UNIVERSITY_ADMIN
  DEZAI_ADMIN
  ORGANIZATION_ADMIN
  ORGANIZATION_MANAGER
  EMPLOYEE
}

model Institution {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?
  description String?
  country     String?
  state       String?
  city        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  faculty             FacultyMember[]
  admins              InstitutionAdmin[]
  programs            Program[]
  credentials         Credential[]
  questionBanks       QuestionBank[]
  credentialTemplates CredentialTemplate[]

  @@map("institutions")
}

model InstitutionAdmin {
  id            String      @id @default(uuid())
  userId        String      @unique
  institutionId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("institution_admins")
}

model FacultyMember {
  id                 String                    @id @default(uuid())
  userId             String                    @unique
  institutionId      String
  department         String?
  designation        String?
  verificationStatus FacultyVerificationStatus @default(PENDING)
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution        Institution               @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  programs           Program[]
  questionBanks      QuestionBank[]

  @@map("faculty_members")
}

enum FacultyVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Program {
  id            String   @id @default(uuid())
  title         String
  description   String
  thumbnail     String?
  institutionId String
  facultyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution  Institution    @relation(fields: [institutionId], references: [id])
  faculty      FacultyMember? @relation(fields: [facultyId], references: [id])
  tracks       ProgramTrack[]
  enrollments  Enrollment[]
  credentials  Credential[]
  chatSessions ChatSession[]

  @@map("programs")
}

model ProgramTrack {
  id          String    @id @default(uuid())
  programId   String
  type        TrackType
  title       String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  program Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  modules Module[]

  @@map("program_tracks")
}

enum TrackType {
  ROOTS
  EDGE
}

enum EnrollmentStatus {
  ACTIVE
  DROPPED
  COMPLETED
}

model Enrollment {
  id          String            @id @default(uuid())
  userId      String
  programId   String
  createdAt   DateTime          @default(now())
  progress    Int               @default(0)
  status      EnrollmentStatus  @default(ACTIVE)
  completedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("enrollments")
}

model Module {
  id        String   @id @default(uuid())
  trackId   String
  title     String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  track        ProgramTrack  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  assessments  Assessment[]
  chatSessions ChatSession[]

  @@map("modules")
}

model Lesson {
  id            String        @id @default(uuid())
  moduleId      String
  title         String
  content       String // Markdown or Rich Text structure
  contentFormat ContentFormat @default(MARKDOWN)
  videoUrl      String?
  order         Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  module       Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progresses   Progress[]
  bookmarks    Bookmark[]
  notes        Note[]
  chatSessions ChatSession[]
  resources    Resource[]

  @@map("lessons")
}

model Progress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("progresses")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("bookmarks")
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  content   String
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("notes")
}

model QuestionBank {
  id            String   @id @default(uuid())
  title         String
  description   String?
  institutionId String
  facultyId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution            @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  faculty     FacultyMember?         @relation(fields: [facultyId], references: [id])
  questions   QuestionBankQuestion[]
  assessments Assessment[]

  @@map("question_banks")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model QuestionBankQuestion {
  id             String             @id @default(uuid())
  questionBankId String
  text           String
  category       String?
  difficulty     Difficulty         @default(MEDIUM)
  tags           String[]           @default([])
  timerSeconds   Int                @default(60) // countdown-per-question limit
  createdAt      DateTime           @default(now())

  questionBank   QuestionBank     @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  options        QuestionOption[]
  attemptAnswers AttemptAnswer[]

  @@map("question_bank_questions")
}

model QuestionOption {
  id         String  @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)

  question       QuestionBankQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptAnswers AttemptAnswer[]

  @@map("question_options")
}

model Assessment {
  id               String   @id @default(uuid())
  moduleId         String
  questionBankId   String
  title            String
  passingScore     Int      @default(80) // Passing percentage
  sampleSize       Int      @default(15) // Dynamic question pull count
  timeLimit        Int      @default(1800) // Total exam duration in seconds (default 30 min)
  timeLimitEnabled Boolean  @default(true) // Whether time limit is enforced
  maxAttempts      Int      @default(8) // Max attempts allowed (faculty configurable)
  allowResume      Boolean  @default(true) // Whether students can resume interrupted attempts
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  module       Module              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questionBank QuestionBank        @relation(fields: [questionBankId], references: [id])
  attempts     AssessmentAttempt[]
  examSessions ExamSession[]

  @@map("assessments")
}

model AssessmentAttempt {
  id           String    @id @default(uuid())
  userId       String
  assessmentId String
  score        Int       @default(0)
  passed       Boolean   @default(false)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment     Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  violations     ViolationLog[]
  attemptAnswers AttemptAnswer[]

  @@map("assessment_attempts")
}

model AttemptAnswer {
  id               String   @id @default(uuid())
  attemptId        String
  questionId       String
  selectedOptionId String
  isCorrect        Boolean  @default(false)
  answeredAt       DateTime @default(now())

  attempt        AssessmentAttempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       QuestionBankQuestion @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption       @relation(fields: [selectedOptionId], references: [id])

  @@map("attempt_answers")
}

model ViolationLog {
  id        String        @id @default(uuid())
  attemptId String?
  sessionId String?
  userId    String
  type      ViolationType
  loggedAt  DateTime      @default(now())

  attempt AssessmentAttempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  session ExamSession?       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("violation_logs")
}

enum ViolationType {
  TAB_SWITCH
  COPY_PASTE
  FOCUS_LOSS
}

model XpTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  type      XpType
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp_transactions")
}

enum XpType {
  DAILY_STREAK
  MODULE_COMPLETION
  ASSESSMENT_PASS
  ACHIEVEMENT_REWARD
}

model Achievement {
  id          String              @id @default(uuid())
  key         String              @unique
  title       String
  description String
  category    AchievementCategory
  rarity      AchievementRarity
  icon        String
  xpReward    Int                 @default(0)
  criteria    Json

  userAchievements UserAchievement[]

  @@map("achievements")
}

enum AchievementCategory {
  STREAK
  XP
  COMPLETION
  ASSESSMENT
  ENGAGEMENT
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model UserAchievement {
  id            String    @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime  @default(now())
  progress      Int       @default(0)
  current       Int       @default(0)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Credential {
  id                 String         @id @default(uuid())
  userId             String
  programId          String
  institutionId      String
  issuedById         String
  tier               CredentialTier
  verificationCode   String         @unique
  verificationUrl    String
  verificationStatus VerifyStatus   @default(ACTIVE)
  metadata           String?
  issuedAt           DateTime       @default(now())

  user                 User                @relation("EarnedCredentials", fields: [userId], references: [id], onDelete: Cascade)
  program              Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  institution          Institution         @relation(fields: [institutionId], references: [id])
  issuer               User                @relation("IssuedCredentials", fields: [issuedById], references: [id])
  credentialTemplate   CredentialTemplate? @relation(fields: [credentialTemplateId], references: [id])
  credentialTemplateId String?

  @@map("credentials")
}

enum CredentialTier {
  FORGE
  ARENA
  CITADEL
}

enum VerifyStatus {
  ACTIVE
  REVOKED
  SUSPENDED
}

model Upload {
  id         String   @id @default(uuid())
  userId     String
  fileName   String
  fileType   String
  fileUrl    String
  sizeBytes  Int
  entityType String? // Optional type of entity attached (e.g. ProgramLogo)
  entityId   String? // Optional ID of entity attached
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("uploads")
}

model ChatSession {
  id              String   @id @default(uuid())
  userId          String
  title           String?
  activeProgramId String?
  activeModuleId  String?
  activeLessonId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  program  Program?      @relation(fields: [activeProgramId], references: [id])
  module   Module?       @relation(fields: [activeModuleId], references: [id])
  lesson   Lesson?       @relation(fields: [activeLessonId], references: [id])
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String     @id @default(uuid())
  sessionId String
  sender    ChatSender
  content   String
  createdAt DateTime   @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

enum ChatSender {
  USER
  MENTOR
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  archived  Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  REMINDER
  CREDENTIAL
  UPDATE
  SYSTEM
  ANNOUNCEMENT
}

enum AuditAction {
  LOGIN
  PROGRAM_CREATED
  PROGRAM_UPDATED
  ASSESSMENT_PUBLISHED
  CREDENTIAL_ISSUED
  ROLE_CHANGED
  PROFILE_UPDATED
  INSTITUTION_CREATED
  INSTITUTION_UPDATED
  FACULTY_VERIFIED
  ENROLLMENT_CREATED
  ENROLLMENT_DROPPED
  LESSON_CREATED
  LESSON_UPDATED
  LESSON_COMPLETED
  CHAT_SESSION_CREATED
  CHAT_SESSION_DELETED
  NOTIFICATION_SENT
  XP_AWARDED
  BOOKMARK_TOGGLED
  NOTE_CREATED
  PROCTORING_VIOLATION
  XP_TRANSACTION
  XP_THRESHOLD_UNLOCKED
  PAYMENT_RECEIVED
  ACCESS_GRANTED
  LEADERBOARD_FROZEN
  VOUCHER_ISSUED
  EXAM_LOCKOUT_TRIGGERED
  QUESTION_BANK_CREATED
  QUESTION_BANK_UPDATED
  QUESTION_BANK_DELETED
  ORGANIZATION_CREATED
  EMPLOYEE_INVITED
  EMPLOYEE_JOINED
  COMPLIANCE_ASSESSMENT_PUBLISHED
  ENTERPRISE_CREDENTIAL_ISSUED
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  userHash  String      @default("")
  userRole  UserRole    @default(STUDENT)
  action    AuditAction
  details   String? // Description or JSON metadata
  ipAddress String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ExamSession {
  id             String     @id @default(uuid())
  userId         String
  assessmentId   String
  status         ExamStatus @default(ACTIVE)
  warningsCount  Int        @default(0)
  scoreDeduction Int        @default(0)
  startedAt      DateTime   @default(now())
  endedAt        DateTime?
  lockoutUntil   DateTime?
  questionSet    Json? // locked, shuffled questions+options for this session
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  violations ViolationLog[]

  @@map("exam_sessions")
}

enum ExamStatus {
  ACTIVE
  SUBMITTED
  TERMINATED
}

enum ContentFormat {
  MARKDOWN
  HTML
}

model Resource {
  id        String   @id @default(uuid())
  lessonId  String
  title     String
  type      String
  url       String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("resources")
}

enum CredentialType {
  PROGRAM
  ASSESSMENT
  MERIT
}

model CredentialTemplate {
  id            String         @id @default(uuid())
  name          String
  type          CredentialType
  description   String?
  defaultTier   CredentialTier @default(CITADEL)
  institutionId String
  designUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  institution Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  credentials Credential[]

  @@map("credential_templates")
}

// Proposed Sprint 8 Enterprise Additions

model Organization {
  id           String    @id @default(uuid())
  name         String
  logoUrl      String?
  industry     String?
  size         OrgSize?
  billingEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  departments             Department[]
  employees               Employee[]
  orgAdmins               OrganizationAdmin[]
  enterpriseQuestionBanks EnterpriseQuestionBank[]
  complianceAssessments   ComplianceAssessment[]
  enterpriseCredentials   EnterpriseCredential[]
  enterpriseTemplates     EnterpriseCredentialTemplate[]

  @@map("organizations")
}

model OrganizationAdmin {
  id             String       @id @default(uuid())
  userId         String       @unique
  organizationId String
  role           OrgAdminRole
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_admins")
}

model Department {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  managerId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager                 Employee?                @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees               Employee[]               @relation("DepartmentEmployees")
  complianceAssessments   ComplianceAssessment[]
  enterpriseQuestionBanks EnterpriseQuestionBank[]

  @@map("departments")
}

model Employee {
  id               String           @id @default(uuid())
  userId           String           @unique
  organizationId   String
  departmentId     String?
  title            String?
  employmentStatus EmploymentStatus @default(INVITED)
  invitedAt        DateTime?
  joinedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user                  User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department            Department?                    @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments    Department[]                   @relation("DepartmentManager")
  complianceAttempts    ComplianceAssessmentAttempt[]
  enterpriseCredentials EnterpriseCredential[]

  @@map("employees")
}

model EnterpriseQuestionBank {
  id               String                 @id @default(uuid())
  title            String
  description      String?
  organizationId   String
  departmentId     String?
  complianceTrack  ComplianceTrack
  sourceType       QuestionBankSourceType @default(MANUAL)
  sourceDocumentId String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  questions             EnterpriseQuestion[]
  complianceAssessments ComplianceAssessment[]

  @@map("enterprise_question_banks")
}

model EnterpriseQuestion {
  id             String                 @id @default(uuid())
  questionBankId String
  text           String
  category       String?
  difficulty     Difficulty             @default(MEDIUM)
  explanation    String?
  tags           String[]               @default([])
  timerSeconds   Int                    @default(60)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  questionBank   EnterpriseQuestionBank @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  options        EnterpriseQuestionOption[]
  attemptAnswers ComplianceAttemptAnswer[]

  @@map("enterprise_questions")
}

model EnterpriseQuestionOption {
  id         String             @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean            @default(false)

  question       EnterpriseQuestion     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptAnswers ComplianceAttemptAnswer[]

  @@map("enterprise_question_options")
}

model ComplianceAssessment {
  id               String                       @id @default(uuid())
  organizationId   String
  departmentId     String?
  questionBankId   String
  title            String
  complianceTrack  ComplianceTrack
  passingScore     Int                          @default(80)
  sampleSize       Int                          @default(15)
  timeLimit        Int                          @default(900)
  timeLimitEnabled Boolean                      @default(true)
  maxAttempts      Int                          @default(3)
  allowResume      Boolean                      @default(true)
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  organization          Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department            Department?                 @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  questionBank          EnterpriseQuestionBank      @relation(fields: [questionBankId], references: [id])
  attempts              ComplianceAssessmentAttempt[]
  enterpriseCredentials EnterpriseCredential[]

  @@map("compliance_assessments")
}

model ComplianceAssessmentAttempt {
  id               String                     @id @default(uuid())
  userId           String
  employeeId       String
  assessmentId     String
  score            Int                        @default(0)
  percentage       Float                      @default(0.0)
  passed           Boolean                    @default(false)
  startedAt        DateTime                   @default(now())
  completedAt      DateTime?
  timeTakenSeconds Int?

  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employee       Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assessment     ComplianceAssessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  attemptAnswers ComplianceAttemptAnswer[]

  @@map("compliance_assessment_attempts")
}

model ComplianceAttemptAnswer {
  id               String                      @id @default(uuid())
  attemptId        String
  questionId       String
  selectedOptionId String
  isCorrect        Boolean                     @default(false)
  answeredAt       DateTime                    @default(now())

  attempt        ComplianceAssessmentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       EnterpriseQuestion           @relation(fields: [questionId], references: [id])
  selectedOption EnterpriseQuestionOption     @relation(fields: [selectedOptionId], references: [id])

  @@map("compliance_attempt_answers")
}

model EnterpriseCredential {
  id                     String                       @id @default(uuid())
  employeeId             String
  organizationId         String
  complianceAssessmentId String?
  complianceTrack        ComplianceTrack
  verificationCode       String                       @unique
  qrCodeUrl              String?
  verificationUrl        String
  verificationStatus     VerifyStatus                 @default(ACTIVE)
  issuedAt               DateTime                     @default(now())

  employee             Employee                     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization         Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  complianceAssessment ComplianceAssessment?        @relation(fields: [complianceAssessmentId], references: [id], onDelete: SetNull)
  template             EnterpriseCredentialTemplate? @relation(fields: [templateId], references: [id])
  templateId           String?

  @@map("enterprise_credentials")
}

model EnterpriseCredentialTemplate {
  id             String                 @id @default(uuid())
  name           String
  complianceTrack ComplianceTrack
  organizationId String
  designUrl      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  credentials    EnterpriseCredential[]

  @@map("enterprise_credential_templates")
}

enum ComplianceTrack {
  CYBER_SECURITY
  PASSWORD_SECURITY
  DATA_PRIVACY
  SECURE_EMAIL
}

